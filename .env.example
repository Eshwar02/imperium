# Imperium — env template. Copy to .env and fill.

# --- Postgres (RKB relational store) ---
POSTGRES_DSN=postgresql+psycopg://imperium:imperium@localhost:5432/imperium

# --- Qdrant (RKB embeddings) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=imperium_rkb

# --- Neo4j (RKB knowledge graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=imperium123

# --- Redis (cache) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM providers (Phase 1) — NO OpenAI / OpenRouter ---
# Per-agent routing lives in backend/imperium/llm/routing.py.
# NVIDIA Nemotron — orchestrator, business-logic, edge-case reasoning
NVIDIA_API_KEY=changeme
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
# Groq — documentation, orchestrator fallback
GROQ_API_KEY=changeme
GROQ_MODEL=llama-3.3-70b-versatile
# Cerebras — structure, security, compatibility, comprehension
CEREBRAS_API_KEY=changeme
CEREBRAS_MODEL=llama-3.3-70b
# Mistral Codestral — implementation, test codegen
MISTRAL_API_KEY=changeme
MISTRAL_MODEL=codestral-latest
# Gemini — research (long context), fallback
GEMINI_API_KEY=changeme
GEMINI_MODEL=gemini-2.0-flash

# --- Sandbox ---
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT_SECONDS=120

# --- App ---
IMPERIUM_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
WORKSPACE_DIR=./.imperium/workspaces
